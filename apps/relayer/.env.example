# Solana cluster (devnet only)
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Relayer keypair (signer = config.trusted_relayer di pulse_payment)
RELAYER_KEYPAIR_PATH=./.keys/pulse-relayer.json

# Program IDs
PULSE_PAYMENT_PROGRAM_ID=2q7mj25BboC3th75YesFFdcSR3e76a45mKKJukQXAUiF
PULSE_LZ_OAPP_PROGRAM_ID=AUdFnYGNTsKRvdCNyRRZcUVo7h8x2nf74e1RMYSF1Nm8
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

POLL_INTERVAL_MS=4000
EVM_POLL_INTERVAL_MS=5000
COMMITMENT=confirmed
LOG_LEVEL=info

# === EVM listener (primary path, bypass LZ) ===
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Set address PulseSender per chain; listener mengaktifkan diri saat env-nya ada.
PULSE_SENDER_BASE_SEPOLIA=
PULSE_SENDER_ARB_SEPOLIA=

# Solana LZ backup listener — aktifkan saat LZ V2 receive config sudah wire.
ENABLE_SOLANA_LZ_LISTENER=false

# Database (opsional — untuk persist Transaction records)
DATABASE_URL=
