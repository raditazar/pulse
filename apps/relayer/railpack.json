{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "cd ../.. && pnpm install --frozen-lockfile"
      ]
    },
    "build": {
      "inputs": ["..."],
      "commands": [
        "cd ../.. && pnpm --filter @pulse/relayer build"
      ]
    }
  },
  "deploy": {
    "startCommand": "node dist/index.js"
  }
}
