# RPC endpoints
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Deployer
PRIVATE_KEY=

# Verifier API keys
BASESCAN_API_KEY=
ARBISCAN_API_KEY=

# LayerZero V2 Endpoint addresses (per chain). Source: layerzero.network/deployments.
# Base Sepolia (eid 40245) & Arb Sepolia (eid 40231) share endpoint address pattern.
LZ_ENDPOINT_V2_BASE_SEPOLIA=0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_ENDPOINT_V2_ARB_SEPOLIA=0x6EDCE65403992e310A62460808c4b910D972f10f

# Solana destination EID (LZ V2 testnet for Solana Devnet)
SOLANA_DEVNET_EID=40168

# Pulse Solana OApp program ID — left-padded ke 32 bytes saat set_peer.
# Program ID: AUdFnYGNTsKRvdCNyRRZcUVo7h8x2nf74e1RMYSF1Nm8
# Hex: 0x8b2b3b9b8fa5d35dbe79e6dc8b1f0a0e4a7e08f4f5b7e8c0d1e2f3a4b5c6d7e8 (placeholder — derive from program ID)
PULSE_SOLANA_OAPP_PROGRAM_ID_HEX=

# Deployed addresses (filled in after deploy)
MOCK_USDC_BASE_SEPOLIA=
MOCK_USDC_ARB_SEPOLIA=
PULSE_SENDER_BASE_SEPOLIA=
PULSE_SENDER_ARB_SEPOLIA=
