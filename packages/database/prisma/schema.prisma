generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id             String   @id @default(cuid())
  name           String
  walletAddress  String
  platformFeeBps Int      @default(1000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
