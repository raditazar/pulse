generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  walletAddress String    @map("wallet_address")
  splitAddress  String?   @map("split_address")
  splitPercent  Int       @default(10) @map("split_percent") // % ke platform/lokasi, sisanya ke merchant
  sessions      Session[]

  @@map("merchants")
}

model Session {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId String?   @map("merchant_id") @db.Uuid
  amount     Decimal   @db.Decimal
  status     String?   @default("pending")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  merchant   Merchant? @relation(fields: [merchantId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sessions")
}
