{
  "name": "@pulse/solana",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./connection": {
      "types": "./src/connection.ts",
      "import": "./dist/connection.js"
    },
    "./transactions": {
      "types": "./src/transactions/index.ts",
      "import": "./dist/transactions/index.js"
    },
    "./cross-chain": {
      "types": "./src/cross-chain/index.ts",
      "import": "./dist/cross-chain/index.js"
    },
    "./lz": {
      "types": "./src/lz/index.ts",
      "import": "./dist/lz/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/connection.ts src/transactions/index.ts src/cross-chain/index.ts src/lz/index.ts --format esm --target node22 --out-dir dist --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
